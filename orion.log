2026-03-28 12:11:28,778 [INFO] utils.orchestrator: Orquestrador acionou tool: escrever_arquivo args={'caminho': 'modulos/futebol.py', 'conteudo': 'import requests\nfrom datetime import datetime\n\ndef run(query="flamengo"):\n    try:\n        # API gratuita do football-data.org\n        # Flamengo ID = 558 na API\n        headers = {"X-Auth-Token": ""}\n        \n        # Usando TheSportsDB (100% gratuita, sem token)\n        team_name = query.lower()\n        \n        # Buscar o time\n        url_team = f"https://www.thesportsdb.com/api/v1/json/3/searchteams.php?t={team_name}"\n        r = requests.get(url_team, timeout=10)\n        data = r.json()\n        \n        if not data.get("teams"):\n            return f"Time \'{query}\' não encontrado."\n        \n        team = data["teams"][0]\n        team_id = team["idTeam"]\n        team_name_official = team["strTeam"]\n        \n        # Buscar próximos jogos\n        url_next = f"https://www.thesportsdb.com/api/v1/json/3/eventsnext.php?id={team_id}"\n        r2 = requests.get(url_next, timeout=10)\n        data2 = r2.json()\n        \n        if not data2.get("events"):\n            return f"Nenhum jogo futuro encontrado para {team_name_official}."\n        \n        evento = data2["events"][0]\n        home = evento.get("strHomeTeam", "?")\n        away = evento.get("strAwayTeam", "?")\n        date_str = evento.get("dateEvent", "?")\n        time_str = evento.get("strTime", "?")\n        league = evento.get("strLeague", "?")\n        venue = evento.get("strVenue", "?")\n        \n        # Formatar data\n        try:\n            dt = datetime.strptime(date_str, "%Y-%m-%d")\n            date_formatted = dt.strftime("%d/%m/%Y")\n        except:\n            date_formatted = date_str\n        \n        result = (\n            f"⚽ Próximo jogo do {team_name_official}:\\n"\n            f"🏆 Competição: {league}\\n"\n            f"🆚 {home} x {away}\\n"\n            f"📅 Data: {date_formatted}\\n"\n            f"🕐 Horário: {time_str} (UTC)\\n"\n            f"🏟️ Estádio: {venue}"\n        )\n        return result\n        \n    except Exception as e:\n        return f"Erro ao buscar jogo: {str(e)}"\n\nif __name__ == "__main__":\n    print(run("flamengo"))\n'}
